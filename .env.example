# ── Supabase ────────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<anon-key>

# ── Clio OAuth ───────────────────────────────────────────────────────────────
# client_id is safe to expose in the frontend (used to construct auth URL)
VITE_CLIO_CLIENT_ID=<clio-client-id>
# Must match exactly what's registered in the Clio OAuth app
VITE_CLIO_REDIRECT_URI=https://practiceiq.netlify.app/auth/clio

# ── Google OAuth ─────────────────────────────────────────────────────────────
VITE_GOOGLE_CLIENT_ID=<google-client-id>
# Must be added to "Authorized redirect URIs" in Google Cloud Console
VITE_GOOGLE_REDIRECT_URI=https://practiceiq.netlify.app/auth/google

# ── Edge Function secrets (set in Supabase Dashboard → Edge Functions → Secrets)
# These never appear in the frontend bundle.
#
# SUPABASE_URL                (auto-injected by Supabase)
# SUPABASE_ANON_KEY           (auto-injected by Supabase)
# SUPABASE_SERVICE_ROLE_KEY   (auto-injected by Supabase)
#
# CLIO_CLIENT_ID=<clio-client-id>
# CLIO_CLIENT_SECRET=<clio-client-secret>
# CLIO_REDIRECT_URI=https://practiceiq.netlify.app/auth/clio
#
# PLAID_CLIENT_ID=<plaid-client-id>
# PLAID_SECRET=<plaid-secret>
# PLAID_ENV=sandbox                    # change to "production" when live
#
# GOOGLE_CLIENT_ID=<google-client-id>
# GOOGLE_CLIENT_SECRET=<google-client-secret>
# GOOGLE_REDIRECT_URI=https://practiceiq.netlify.app/auth/google
#
# ANTHROPIC_API_KEY=<anthropic-api-key>
#
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_PRICE_ID=price_...           # $99/mo recurring price
# STRIPE_WEBHOOK_SECRET=whsec_...     # from Stripe Dashboard → Webhooks
#
# RESEND_API_KEY=re_...
#
# CRON_SECRET=<random-secret>          # shared between pg_cron calls and Edge Functions
